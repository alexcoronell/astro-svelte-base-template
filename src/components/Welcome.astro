---
import astroLogo from "../assets/astro.svg";
import background from "../assets/background.svg";
---

<!-- Background elements -->
<div class="grid-bg"></div>
<div class="glow-orb glow-orb-1"></div>
<div class="glow-orb glow-orb-2"></div>

<!-- Main container -->
<main
  class="w-full min-h-screen max-h-screen overflow-hidden flex flex-col justify-center items-center px-6 py-12 lg:px-12"
>
  <div class="max-w-5xl mx-auto w-full relative z-10">
    <!-- Header badge -->
    <div class="animate-fade-up delay-1 mb-6">
      <span class="version-badge">
        <svg
          width="12"
          height="12"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <polygon
            points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"
          ></polygon>
        </svg>
        Template v1.0
      </span>
    </div>

    <!-- Main headline -->
    <h1
      class="animate-fade-up delay-2 text-4xl sm:text-5xl lg:text-7xl font-bold tracking-tight leading-[1.1] mb-6"
    >
      <span class="block text-[var(--fg)]">Astro + Svelte</span>
      <span class="block text-[var(--accent)]">Starter Kit</span>
    </h1>

    <!-- Description -->
    <p
      class="animate-fade-up delay-3 text-lg sm:text-xl text-(--muted) max-w-xl mb-10 leading-relaxed"
    >
      A production-ready template with the best development tools. Zero-touch
      configuration to start building immediately.
    </p>

    <!-- CTA Button (Only GitHub) -->
    <div class="animate-fade-up delay-4 mb-16">
      <a href="#" class="secondary-btn"> View on GitHub </a>
    </div>

    <!-- Tools section -->
    <div class="animate-fade-up delay-5">
      <p class="text-xs uppercase tracking-wider text-(--muted) mb-4 font-mono">
        Included Tools
      </p>

      <div class="grid grid-cols-2 sm:grid-cols-3 gap-4 max-w-3xl">
        <!-- Svelte -->
        <div class="tool-card" tabindex="0" aria-label="Svelte">
          <div class="flex items-center gap-3 relative z-10">
            <div class="logo-icon">
              <!-- Svelte Logo -->
              <svg
                width="22"
                height="22"
                viewBox="0 0 24 24"
                fill="none"
                class="logo-svelte"
              >
                <path
                  d="M20.68 3.17a7.2 7.2 0 0 0-9.83-2.33L4.62 5.29a6.83 6.83 0 0 0-3.06 4.64 6.71 6.71 0 0 0 .68 4.57 6.83 6.83 0 0 0-.96 3.08 6.94 6.94 0 0 0 1.2 4.45 7.2 7.2 0 0 0 9.83 2.33l6.23-4.45a6.83 6.83 0 0 0 3.06-4.64 6.71 6.71 0 0 0-.68-4.57 6.94 6.94 0 0 0-1.24-7.53z"
                  fill="currentColor"
                  fill-opacity="0.2"></path>
                <path
                  d="M10.54 20.18a4.17 4.17 0 0 1-4.48-1.62 3.84 3.84 0 0 1-.66-2.46 3.77 3.77 0 0 1 .12-.63l.15-.54.47.34a10.38 10.38 0 0 0 3.15 1.57l.3.1v.28a1.16 1.16 0 0 0 .23.76 1.24 1.24 0 0 0 1.33.46 1.13 1.13 0 0 0 .67-.38l6.23-4.45a1.16 1.16 0 0 0 .36-1.1 1.18 1.18 0 0 0-.48-.72 1.25 1.25 0 0 0-.84-.22h-.04a1.14 1.14 0 0 0-.62.24l-2.37 1.7a4.17 4.17 0 0 1-2.34.75 4.17 4.17 0 0 1-4.48-1.62 3.84 3.84 0 0 1-.66-2.46 3.78 3.78 0 0 1 .62-1.95 3.85 3.85 0 0 1 1.74-1.42l6.23-4.45a4.17 4.17 0 0 1 2.34-.75 4.17 4.17 0 0 1 4.48 1.62 3.84 3.84 0 0 1 .66 2.46 3.77 3.77 0 0 1-.12.63l-.15.54-.47-.34a10.38 10.38 0 0 0-3.15-1.57l-.3-.1v-.28a1.16 1.16 0 0 0-.23-.76 1.24 1.24 0 0 0-1.33-.46 1.13 1.13 0 0 0-.67.38l-6.23 4.45a1.16 1.16 0 0 0-.36 1.1 1.18 1.18 0 0 0 .48.72 1.25 1.25 0 0 0 .84.22h.04a1.14 1.14 0 0 0 .62-.24l2.37-1.7a4.17 4.17 0 0 1 2.34-.75 4.17 4.17 0 0 1 4.48 1.62 3.84 3.84 0 0 1 .66 2.46 3.78 3.78 0 0 1-.62 1.95 3.85 3.85 0 0 1-1.74 1.42l-6.23 4.45a4.17 4.17 0 0 1-2.34.75z"
                  fill="currentColor"></path>
              </svg>
            </div>
            <div>
              <span class="font-medium text-sm">Svelte</span>
              <span class="block text-xs text-(--muted)">Framework</span>
            </div>
          </div>
        </div>

        <!-- ESLint -->
        <div class="tool-card" tabindex="0" aria-label="ESLint">
          <div class="flex items-center gap-3 relative z-10">
            <div class="logo-icon">
              <svg
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                class="logo-eslint"
              >
                <path
                  d="M12 2L2 7.5V16.5L12 22L22 16.5V7.5L12 2Z"
                  stroke="currentColor"
                  stroke-width="1.5"></path>
                <path
                  d="M12 6L7 8.5V13.5L12 16L17 13.5V8.5L12 6Z"
                  fill="currentColor"></path>
              </svg>
            </div>
            <div>
              <span class="font-medium text-sm">ESLint</span>
              <span class="block text-xs text-(--muted)">Linting</span>
            </div>
          </div>
        </div>

        <!-- Prettier -->
        <div class="tool-card" tabindex="0" aria-label="Prettier">
          <div class="flex items-center gap-3 relative z-10">
            <div class="logo-icon">
              <svg
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                class="logo-prettier"
              >
                <path
                  d="M4 6h16M4 12h16M4 18h10"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"></path>
                <circle cx="19" cy="18" r="2" fill="currentColor"></circle>
              </svg>
            </div>
            <div>
              <span class="font-medium text-sm">Prettier</span>
              <span class="block text-xs text-(--muted)">Formatting</span>
            </div>
          </div>
        </div>

        <!-- Vitest -->
        <div class="tool-card" tabindex="0" aria-label="Vitest">
          <div class="flex items-center gap-3 relative z-10">
            <div class="logo-icon">
              <svg
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                class="logo-vitest"
              >
                <path
                  d="M12 2L2 19h20L12 2z"
                  fill="currentColor"
                  fill-opacity="0.2"></path>
                <path
                  d="M8.5 14l3 3 5-6"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
              </svg>
            </div>
            <div>
              <span class="font-medium text-sm">Vitest</span>
              <span class="block text-xs text-(--muted)">Unit Testing</span>
            </div>
          </div>
        </div>

        <!-- Playwright -->
        <div class="tool-card" tabindex="0" aria-label="Playwright">
          <div class="flex items-center gap-3 relative z-10">
            <div class="logo-icon">
              <svg
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                class="logo-playwright"
              >
                <rect
                  x="3"
                  y="3"
                  width="18"
                  height="18"
                  rx="2"
                  stroke="currentColor"
                  stroke-width="1.5"></rect>
                <path
                  d="M8 12l3 3 5-6"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
              </svg>
            </div>
            <div>
              <span class="font-medium text-sm">Playwright</span>
              <span class="block text-xs text-(--muted)">E2E Testing</span>
            </div>
          </div>
        </div>

        <!-- Husky -->
        <div class="tool-card" tabindex="0" aria-label="Husky">
          <div class="flex items-center gap-3 relative z-10">
            <div class="logo-icon">
              <svg
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                class="logo-husky"
              >
                <ellipse
                  cx="12"
                  cy="14"
                  rx="8"
                  ry="6"
                  stroke="currentColor"
                  stroke-width="1.5"></ellipse>
                <circle cx="9" cy="13" r="1.5" fill="currentColor"></circle>
                <circle cx="15" cy="13" r="1.5" fill="currentColor"></circle>
                <path
                  d="M12 2c-2 2-3 4-3 6M12 2c2 2 3 4 3 6"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"></path>
              </svg>
            </div>
            <div>
              <span class="font-medium text-sm">Husky</span>
              <span class="block text-xs text-(--muted)">Git Hooks</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Footer stats -->
  <footer
    class="animate-fade-in delay-7 absolute bottom-6 left-6 right-6 lg:left-12 lg:right-12 flex items-center justify-center"
  >
    <div
      class="max-w-5xl mx-auto flex flex-wrap items-center justify-between gap-4 text-xs text-(--muted)"
    >
      <div class="flex items-center gap-6">
        <span class="flex items-center gap-2">
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"
            ></path>
          </svg>
          Zero config
        </span>
        <span class="flex items-center gap-2">
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"></path>
          </svg>
          Ultra fast
        </span>
      </div>
      <span class="font-mono">MIT License</span>
    </div>
  </footer>
</main>

<style>
  /* Grid background */
  .grid-bg {
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(rgba(0, 212, 170, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 212, 170, 0.03) 1px, transparent 1px);
    background-size: 60px 60px;
    pointer-events: none;
  }

  /* Static Glow Orbs (No JS) */
  .glow-orb {
    position: fixed;
    width: 600px;
    height: 600px;
    border-radius: 50%;
    pointer-events: none;
    filter: blur(80px);
    z-index: 0;
  }

  .glow-orb-1 {
    top: -200px;
    right: -100px;
    background: radial-gradient(
      circle,
      rgba(0, 212, 170, 0.15) 0%,
      transparent 70%
    );
  }

  .glow-orb-2 {
    bottom: -300px;
    left: -200px;
    background: radial-gradient(
      circle,
      rgba(255, 62, 0, 0.1) 0%,
      transparent 70%
    );
  }

  /* Animations */
  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  .animate-fade-up {
    animation: fadeUp 0.8s ease-out forwards;
    opacity: 0;
  }

  .animate-fade-in {
    animation: fadeIn 0.6s ease-out forwards;
    opacity: 0;
  }

  .delay-1 {
    animation-delay: 0.1s;
  }
  .delay-2 {
    animation-delay: 0.2s;
  }
  .delay-3 {
    animation-delay: 0.3s;
  }
  .delay-4 {
    animation-delay: 0.4s;
  }
  .delay-5 {
    animation-delay: 0.5s;
  }
  .delay-6 {
    animation-delay: 0.6s;
  }
  .delay-7 {
    animation-delay: 0.7s;
  }

  @media (prefers-reduced-motion: reduce) {
    .animate-fade-up,
    .animate-fade-in {
      animation: none;
      opacity: 1;
    }
  }

  /* Tool card */
  .tool-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.25rem;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
  }

  .tool-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(0, 212, 170, 0.08) 0%,
      transparent 50%
    );
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .tool-card:hover {
    border-color: var(--accent);
    transform: translateY(-4px);
    box-shadow:
      0 20px 40px rgba(0, 0, 0, 0.3),
      0 0 0 1px var(--accent);
  }

  .tool-card:hover::before {
    opacity: 1;
  }

  .tool-card:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  /* Secondary button */
  .secondary-btn {
    background: transparent;
    color: var(--fg);
    font-weight: 500;
    padding: 1rem 1.5rem;
    border-radius: 8px;
    border: 1px solid var(--border);
    cursor: pointer;
    transition: all 0.2s ease;
    text-decoration: none;
    display: inline-block;
  }

  .secondary-btn:hover {
    border-color: var(--muted);
    background: var(--card);
  }

  .secondary-btn:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  /* Version badge */
  .version-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--accent-dim);
    color: var(--accent);
    padding: 0.375rem 0.75rem;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 500;
    border: 1px solid rgba(0, 212, 170, 0.2);
  }

  /* Logo icon container */
  .logo-icon {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    background: var(--bg);
  }

  /* Brand Colors for Logos */
  .logo-svelte {
    color: #ff3e00;
  }
  .logo-eslint {
    color: #4b32c3;
  }
  .logo-prettier {
    color: #c596c7;
  }
  .logo-husky {
    color: #f9a03c;
  }
  .logo-playwright {
    color: #2ead33;
  }
  .logo-vitest {
    color: #fcc72b;
  }
</style>
